import stdio

pub mod FlowDemo {
    pub container Logic {
        func run() {
            let x = 10

            if x > 5 {
                print("x is greater than 5")
            } else {
                print("x is 5 or less")
            }

            let mut i = 0
            while i < 5 {
                print(i)
                print(" ")
                i = i + 1
            }
        }
    }
}

start FlowDemo
